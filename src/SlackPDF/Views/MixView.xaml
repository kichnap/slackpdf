<UserControl x:Class="SlackPDF.Views.MixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title + description -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="{DynamicResource Mix.Title}"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{DynamicResource Mix.Description}"
                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                       Opacity="0.7" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- File list + side action buttons -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="0">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Bottom" Style="{StaticResource MaterialDesignToolBar}">
                        <Button Content="{DynamicResource Common.AddFiles}"
                                Command="{Binding AddFilesCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Content="{DynamicResource Common.ClearAll}"
                                Command="{Binding ClearAllCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                    </ToolBar>

                    <DataGrid ItemsSource="{Binding Files}"
                              SelectedItem="{Binding SelectedFile}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              materialDesign:DataGridAssist.CellPadding="8 4"
                              AllowDrop="True"
                              PreviewDragOver="FileList_DragOver"
                              PreviewDrop="FileList_Drop">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock Text="{DynamicResource Common.Column.File}"/>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FilePdfBox"
                                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}"/>
                                                <TextBlock FontSize="11" Opacity="0.6">
                                                    <Run Text="{Binding PageCount, Mode=OneWay}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{DynamicResource Common.Pages}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Order column: CheckBox — unchecked = straight, checked = reverse.
                                 RadioButtons in DataGrid are unreliable (shared GroupName across rows);
                                 CheckBox avoids the issue entirely. -->
                            <DataGridTemplateColumn Width="160">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock Text="{DynamicResource Mix.Column.Order}"/>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Reverse, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource MaterialDesignCheckBox}"
                                                  VerticalAlignment="Center">
                                            <CheckBox.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{DynamicResource Mix.Straight}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Reverse}" Value="True">
                                                                    <Setter Property="Text" Value="{DynamicResource Mix.Reverse}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </materialDesign:Card>

            <!-- Side action buttons: fixed position, operate on selected row -->
            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding MoveUpCommand}"
                        ToolTip="{DynamicResource Merge.MoveUp}">
                    <materialDesign:PackIcon Kind="ArrowUp"/>
                </Button>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding MoveDownCommand}"
                        ToolTip="{DynamicResource Merge.MoveDown}">
                    <materialDesign:PackIcon Kind="ArrowDown"/>
                </Button>
                <Separator Margin="8,4"/>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding RemoveFileCommand}"
                        ToolTip="{DynamicResource Merge.Remove}">
                    <materialDesign:PackIcon Kind="Delete"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Output -->
        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding OutputPath}"
                         materialDesign:HintAssist.Hint="{DynamicResource Common.OutputFile}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         IsReadOnly="True" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="{DynamicResource Common.Browse}"
                        Command="{Binding BrowseOutputCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Bottom"/>
            </Grid>
        </materialDesign:Card>

        <!-- Run button -->
        <Button Grid.Row="3"
                Content="{DynamicResource Common.Run}"
                Command="{Binding RunCommand}"
                Style="{StaticResource MaterialDesignRaisedButton}"
                HorizontalAlignment="Left" Padding="32,8"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
    </Grid>
</UserControl>
