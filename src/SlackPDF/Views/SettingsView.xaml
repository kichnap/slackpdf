<UserControl x:Class="SlackPDF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="{DynamicResource Settings.Title}"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Margin="0,0,0,24"/>

            <!-- Language -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Language}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="English"
                                     IsChecked="{Binding IsEnglish}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetLanguageCommand}" CommandParameter="en-US"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="Русский"
                                     IsChecked="{Binding IsRussian}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetLanguageCommand}" CommandParameter="ru-RU"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Theme -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Theme}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="{DynamicResource Settings.Theme.Light}"
                                     IsChecked="{Binding IsLightTheme}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetThemeCommand}" CommandParameter="Light"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="{DynamicResource Settings.Theme.Dark}"
                                     IsChecked="{Binding IsDarkTheme}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetThemeCommand}" CommandParameter="Dark"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Thumbnail cache -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.ThumbnailCache}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <Button Content="{DynamicResource Settings.ClearCache}"
                            Command="{Binding ClearCacheCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               Margin="0,8,0,0" FontSize="12"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- About -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.About}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Settings.Version}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7" Margin="0,0,0,8"/>
                    <TextBlock Text="kichnap"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               FontWeight="Medium" Margin="0,0,0,4"/>
                    <Button Content="{DynamicResource Settings.GitHub}"
                            Command="{Binding OpenGitHubCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalAlignment="Left"
                            Foreground="{DynamicResource PrimaryHueMidBrush}"
                            Padding="0,4"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Open-source components (required attribution for MIT licenses) -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.OpenSource}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,12"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="PDFsharp" FontWeight="Medium" Width="200"/>
                            <TextBlock Text="MIT" Opacity="0.6"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="PDFtoImage" FontWeight="Medium" Width="200"/>
                            <TextBlock Text="MIT" Opacity="0.6"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="SkiaSharp" FontWeight="Medium" Width="200"/>
                            <TextBlock Text="MIT" Opacity="0.6"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="MaterialDesignThemes" FontWeight="Medium" Width="200"/>
                            <TextBlock Text="MIT" Opacity="0.6"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="CommunityToolkit.Mvvm" FontWeight="Medium" Width="200"/>
                            <TextBlock Text="MIT" Opacity="0.6"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
