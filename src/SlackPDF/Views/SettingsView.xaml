<UserControl x:Class="SlackPDF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="600" HorizontalAlignment="Left">

            <TextBlock Text="{DynamicResource Settings.Title}"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Margin="0,0,0,24"/>

            <!-- Language -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Language}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="English"
                                     IsChecked="{Binding IsEnglish}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetLanguageCommand}" CommandParameter="en-US"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="Русский"
                                     IsChecked="{Binding IsRussian}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetLanguageCommand}" CommandParameter="ru-RU"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- PDF Engine -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Engine}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="PDFsharp"
                                     IsChecked="{Binding IsPdfSharp}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetEngineCommand}" CommandParameter="PDFsharp"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="iText"
                                     IsChecked="{Binding IsIText}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetEngineCommand}" CommandParameter="iText"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Theme -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.Theme}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="{DynamicResource Settings.Theme.Light}"
                                     IsChecked="{Binding IsLightTheme}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetThemeCommand}" CommandParameter="Light"
                                     Margin="0,0,16,0"/>
                        <RadioButton Content="{DynamicResource Settings.Theme.Dark}"
                                     IsChecked="{Binding IsDarkTheme}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Command="{Binding SetThemeCommand}" CommandParameter="Dark"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Thumbnail cache -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.ThumbnailCache}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <Button Content="{DynamicResource Settings.ClearCache}"
                            Command="{Binding ClearCacheCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               Margin="0,8,0,0" FontSize="12"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- About -->
            <materialDesign:Card Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Settings.About}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Settings.Version}"
                               Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.7"/>
                </StackPanel>
            </materialDesign:Card>

        </StackPanel>
    </ScrollViewer>
</UserControl>
