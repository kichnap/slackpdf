<UserControl x:Class="SlackPDF.Views.ComposerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SlackPDF.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Style="{StaticResource MaterialDesignToolBar}">
            <TextBlock Text="{DynamicResource Composer.Title}"
                       Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                       VerticalAlignment="Center" Margin="8,0"/>
            <Separator/>
            <Button Content="{DynamicResource Composer.AutoOrder}"
                    Click="AutoOrder_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Button Content="{DynamicResource Common.ClearAll}"
                    Click="ClearAll_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
            <Separator/>
            <Button Content="{DynamicResource Composer.SavePdf}"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Download" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </ToolBar>

        <!-- Main two-panel layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- x:Name so code-behind can read/write Width for persistence -->
                <ColumnDefinition x:Name="SourceColumn" Width="260" MinWidth="180"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Source documents -->
            <DockPanel Grid.Column="0">
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource PrimaryHueLightBrush}"
                        Padding="12,8">
                    <DockPanel>
                        <TextBlock Text="{DynamicResource Composer.Sources}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   VerticalAlignment="Center"/>
                        <!-- + button -->
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding AddDocumentCommand}"
                                ToolTip="{DynamicResource Composer.AddDocument}"
                                Foreground="{DynamicResource PrimaryHueDarkBrush}"
                                Width="32" Height="32">
                            <materialDesign:PackIcon Kind="Plus"/>
                        </Button>
                        <!-- Loading spinner shown while PDF files are being opened -->
                        <ProgressBar DockPanel.Dock="Right"
                                     Style="{StaticResource MaterialDesignCircularProgressBar}"
                                     IsIndeterminate="True" Value="0"
                                     Width="20" Height="20" Margin="0,0,4,0"
                                     Visibility="{Binding IsLoadingDocuments, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </DockPanel>
                </Border>

                <!-- Document tab strip: each label shows a tooltip with file metadata.
                     WrapPanel so tabs flow to the next row when there are many documents. -->
                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding Documents}"
                         SelectedItem="{Binding ActiveDocument}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Left">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ComposerDocument}">
                            <!-- Thin coloured border gives each tab a visual frame; tooltip on the whole tab -->
                            <Border BorderThickness="1" BorderBrush="{Binding ColorBrush}"
                                    CornerRadius="3" Margin="2,3,2,3"
                                    ToolTipService.ShowDuration="10000"
                                    ToolTipService.InitialShowDelay="400">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MinWidth="200">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontWeight="Bold" TextWrapping="Wrap"
                                                       Margin="0,0,0,6"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                <TextBlock Text="{DynamicResource Composer.DocInfo.Pages}"
                                                           Opacity="0.6" Width="100"/>
                                                <TextBlock Text="{Binding PageCount}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                <TextBlock Text="{DynamicResource Composer.DocInfo.Size}"
                                                           Opacity="0.6" Width="100"/>
                                                <TextBlock Text="{Binding FileSizeFormatted}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                                <TextBlock Text="{DynamicResource Composer.DocInfo.PdfVersion}"
                                                           Opacity="0.6" Width="100"/>
                                                <TextBlock Text="{Binding PdfVersion}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                            <Grid MinWidth="48" Margin="2,2,4,2">

                                <!-- Colour dot + letter; top margin leaves room for the × button -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                            Margin="4,4,4,2">
                                    <Ellipse Width="10" Height="10" Fill="{Binding ColorBrush}"
                                             Margin="0,0,2,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Label}" FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Close button — top-right corner -->
                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                        Width="14" Height="14" Padding="0"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Foreground="{DynamicResource MaterialDesignBody}"
                                        Command="{Binding DataContext.RemoveDocumentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{DynamicResource Composer.Menu.Remove}">
                                    <materialDesign:PackIcon Kind="Close" Width="12" Height="12"/>
                                </Button>
                            </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Page thumbnails of active doc.
                     Click = select one. Ctrl+Click = toggle. Shift+Click = range.
                     Drag any selected thumb to move all selected to Assembly.
                     Drop PDF files from Explorer to add them as source documents. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              AllowDrop="True"
                              DragOver="SourcePanel_DragOver"
                              Drop="SourcePanel_Drop">
                    <ItemsControl ItemsSource="{Binding ActiveDocument.Pages}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ComposerPageThumb}">
                                <Border Width="72" Height="100" Margin="4"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="SourceThumb_MouseLeftButtonDown"
                                        MouseMove="SourceThumb_MouseMove"
                                        MouseLeftButtonUp="SourceThumb_MouseLeftButtonUp"
                                        Background="Transparent">
                                    <Grid>
                                        <!-- Thumbnail image (or empty background while loading) -->
                                        <Border BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                                BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToThicknessConverter}}"
                                                Background="#12000000"
                                                CornerRadius="2">
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                   Visibility="{Binding Thumbnail, Converter={StaticResource IsNotNullToVisibilityConverter}}"/>
                                        </Border>

                                        <!-- Silhouette placeholder while thumbnail is not loaded yet -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding Thumbnail, Converter={StaticResource IsNullToVisibilityConverter}}">
                                            <materialDesign:PackIcon Kind="FileOutline" Width="28" Height="36"
                                                                     Foreground="#60808080" HorizontalAlignment="Center"/>
                                            <!-- Warning icon only after a failed load attempt -->
                                            <materialDesign:PackIcon Kind="AlertCircleOutline" Width="14" Height="14"
                                                                     Foreground="#C0FF8800" HorizontalAlignment="Center"
                                                                     Margin="0,3,0,0"
                                                                     Visibility="{Binding ThumbnailFailed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </StackPanel>

                                        <!-- Selection overlay: semi-transparent fill + checkmark -->
                                        <Border Background="#AD1A237E" CornerRadius="2"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <materialDesign:PackIcon Kind="Check" Width="28" Height="28"
                                                                     Foreground="White"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Page number badge -->
                                        <TextBlock Text="{Binding PageIndex, Converter={StaticResource PageIndexToNumberConverter}}"
                                                   FontSize="10" HorizontalAlignment="Center"
                                                   VerticalAlignment="Bottom" Margin="0,0,0,2"
                                                   Background="#88000000" Foreground="White" Padding="2,1"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- x:Name so code-behind can subscribe to DragCompleted for width persistence -->
            <GridSplitter x:Name="SourceSplitter" Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

            <!-- Right: Assembly zone -->
            <DockPanel Grid.Column="2">
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource MaterialDesignToolBarBackground}"
                        Padding="12,8">
                    <DockPanel>
                        <TextBlock Text="{DynamicResource Composer.Assembly}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   VerticalAlignment="Center"/>
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding AssemblyCountLabel}"
                                   Opacity="0.6" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </DockPanel>
                </Border>

                <ScrollViewer x:Name="AssemblyScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              AllowDrop="True"
                              DragOver="Assembly_DragOver"
                              Drop="Assembly_Drop"
                              DragLeave="Assembly_DragLeave">
                    <ItemsControl ItemsSource="{Binding ComposedPages}"
                                  x:Name="AssemblyPanel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Margin="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ComposerPage}">
                                <Border Width="88" Height="120" Margin="4"
                                        Background="{Binding FadedColorBrush}"
                                        BorderBrush="{Binding ColorBrush}"
                                        BorderThickness="2" CornerRadius="4"
                                        Cursor="SizeAll"
                                        ToolTipService.ShowDuration="5000"
                                        MouseLeftButtonDown="AssemblyThumb_MouseLeftButtonDown"
                                        MouseMove="AssemblyThumb_MouseMove">
                                    <Border.ToolTip>
                                        <ToolTip>
                                            <TextBlock Text="{Binding SourceFilePath}"/>
                                        </ToolTip>
                                    </Border.ToolTip>
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="UniformToFill" Margin="2"/>
                                        <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                                 Width="22" Height="22"
                                                                 Foreground="#C0FF8800"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Visibility="{Binding ThumbnailFailed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <Border Background="{Binding ColorBrush}"
                                                CornerRadius="2" Padding="3,1"
                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Margin="3">
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Width="22" Height="22" Margin="2"
                                                Background="#88000000" Foreground="White">
                                            <materialDesign:PackIcon Kind="Close" Width="12" Height="12"/>
                                            <Button.Command>
                                                <Binding Path="DataContext.RemovePageCommand"
                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                            </Button.Command>
                                            <Button.CommandParameter>
                                                <Binding/>
                                            </Button.CommandParameter>
                                        </Button>
                                    </Grid>
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{DynamicResource Composer.Menu.Remove}"
                                                      Command="{Binding DataContext.RemovePageCommand, Source={x:Reference AssemblyPanel}}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="{DynamicResource Composer.Menu.MoveFirst}"
                                                      Command="{Binding DataContext.MovePageFirstCommand, Source={x:Reference AssemblyPanel}}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="{DynamicResource Composer.Menu.MoveLast}"
                                                      Command="{Binding DataContext.MovePageLastCommand, Source={x:Reference AssemblyPanel}}"
                                                      CommandParameter="{Binding}"/>
                                            <MenuItem Header="{DynamicResource Composer.Menu.Duplicate}"
                                                      Command="{Binding DataContext.DuplicatePageCommand, Source={x:Reference AssemblyPanel}}"
                                                      CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Padding="12,4"
                Background="{DynamicResource MaterialDesignToolBarBackground}">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.7"/>
        </Border>
    </Grid>
</UserControl>
