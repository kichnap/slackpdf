<UserControl x:Class="SlackPDF.Views.MergeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SlackPDF.ViewModels">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   Text="{DynamicResource Merge.Title}"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   Margin="0,0,0,16"/>

        <!-- File list + side action buttons -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="0">
                <DockPanel>
                    <ToolBar DockPanel.Dock="Bottom" Style="{StaticResource MaterialDesignToolBar}">
                        <Button Content="{DynamicResource Common.AddFiles}"
                                Command="{Binding AddFilesCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                        <Button Content="{DynamicResource Common.ClearAll}"
                                Command="{Binding ClearAllCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                    </ToolBar>

                    <DataGrid ItemsSource="{Binding Files}"
                              SelectedItem="{Binding SelectedFile}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              materialDesign:DataGridAssist.CellPadding="8 4"
                              AllowDrop="True"
                              PreviewDragOver="FileList_DragOver"
                              PreviewDrop="FileList_Drop">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="*">
                                <DataGridTemplateColumn.Header>
                                    <TextBlock Text="{DynamicResource Common.Column.File}"/>
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FilePdfBox"
                                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding PageCount}" Width="60" IsReadOnly="True">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Merge.Column.Pages}"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding FileSizeFormatted}" Width="80" IsReadOnly="True">
                                <DataGridTextColumn.Header>
                                    <TextBlock Text="{DynamicResource Merge.Column.Size}"/>
                                </DataGridTextColumn.Header>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="{DynamicResource Common.PageSelection}" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Selection, Mode=OneWay}"
                                                 materialDesign:HintAssist.Hint="{DynamicResource Common.PageSelectionHint}"
                                                 Style="{StaticResource MaterialDesignTextBox}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </materialDesign:Card>

            <!-- Side action buttons: fixed position, operate on selected row -->
            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Top">
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding MoveUpCommand}"
                        ToolTip="{DynamicResource Merge.MoveUp}">
                    <materialDesign:PackIcon Kind="ArrowUp"/>
                </Button>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding MoveDownCommand}"
                        ToolTip="{DynamicResource Merge.MoveDown}">
                    <materialDesign:PackIcon Kind="ArrowDown"/>
                </Button>
                <Separator Margin="8,4"/>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding RemoveFileCommand}"
                        ToolTip="{DynamicResource Merge.Remove}">
                    <materialDesign:PackIcon Kind="Delete"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Options -->
        <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0" Margin="0,0,16,0"
                          materialDesign:HintAssist.Hint="{DynamicResource Merge.Bookmarks}"
                          SelectedIndex="{Binding SelectedBookmarkIndex}"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                    <ComboBoxItem Content="{DynamicResource Merge.Bookmarks.Merge}"/>
                    <ComboBoxItem Content="{DynamicResource Merge.Bookmarks.Discard}"/>
                    <ComboBoxItem Content="{DynamicResource Merge.Bookmarks.OneEntry}"/>
                </ComboBox>

                <ComboBox Grid.Column="1" Margin="0,0,16,0"
                          materialDesign:HintAssist.Hint="{DynamicResource Merge.AcroForms}"
                          SelectedIndex="{Binding SelectedAcroFormIndex}"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                    <ComboBoxItem Content="{DynamicResource Merge.AcroForms.Discard}"/>
                    <ComboBoxItem Content="{DynamicResource Merge.AcroForms.Merge}"/>
                    <ComboBoxItem Content="{DynamicResource Merge.AcroForms.MergeRename}"/>
                </ComboBox>

                <CheckBox Grid.Column="2"
                          Content="{DynamicResource Merge.TOC}"
                          IsChecked="{Binding AddTableOfContents}"
                          Style="{StaticResource MaterialDesignCheckBox}"/>
            </Grid>
        </materialDesign:Card>

        <!-- Output -->
        <materialDesign:Card Grid.Row="3" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding OutputPath}"
                         materialDesign:HintAssist.Hint="{DynamicResource Common.OutputFile}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         IsReadOnly="True" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="{DynamicResource Common.Browse}"
                        Command="{Binding BrowseOutputCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </materialDesign:Card>

        <!-- Run button -->
        <Button Grid.Row="4"
                Content="{DynamicResource Common.Run}"
                Command="{Binding RunCommand}"
                Style="{StaticResource MaterialDesignRaisedButton}"
                HorizontalAlignment="Left"
                Padding="32,8"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
    </Grid>
</UserControl>
