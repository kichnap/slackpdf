<UserControl x:Class="SlackPDF.Views.ExtractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="{DynamicResource Extract.Title}"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Margin="0,0,0,16"/>

            <!-- Input -->
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBox Text="{Binding InputFileName}"
                                 materialDesign:HintAssist.Hint="Input PDF file"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 IsReadOnly="True"/>
                        <TextBlock Text="{Binding InputPageCount, StringFormat='Pages: {0}'}"
                                   Margin="0,4,0,0" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{DynamicResource Common.Browse}"
                            Command="{Binding BrowseInputCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Bottom"/>
                </Grid>
            </materialDesign:Card>

            <!-- Page selection -->
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBox Text="{Binding PageSelectionText}"
                             materialDesign:HintAssist.Hint="{DynamicResource Common.PageSelectionHint}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             materialDesign:HintAssist.HelperText="Leave empty to select all pages"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Extract mode -->
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Extract.OutputMode}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <RadioButton Content="{DynamicResource Extract.SingleFile}"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=SingleFile}"
                                 Style="{StaticResource MaterialDesignRadioButton}" Margin="0,4"/>
                    <RadioButton Content="{DynamicResource Extract.OnePerPage}"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=OneFilePerPage}"
                                 Style="{StaticResource MaterialDesignRadioButton}" Margin="0,4"/>
                    <RadioButton Content="{DynamicResource Extract.OnePerRange}"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=OneFilePerRange}"
                                 Style="{StaticResource MaterialDesignRadioButton}" Margin="0,4"/>
                </StackPanel>
            </materialDesign:Card>

            <!-- Output -->
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding OutputPath}"
                             materialDesign:HintAssist.Hint="{DynamicResource Common.OutputFile}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             IsReadOnly="True" Margin="0,0,8,0"/>
                    <Button Grid.Column="1" Content="{DynamicResource Common.Browse}"
                            Command="{Binding BrowseOutputCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" VerticalAlignment="Bottom"/>
                </Grid>
            </materialDesign:Card>

            <Button Content="{DynamicResource Common.Run}"
                    Command="{Binding RunCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    HorizontalAlignment="Left" Padding="32,8"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
