<UserControl x:Class="SlackPDF.Views.RotateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:SlackPDF.ViewModels">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <TextBlock Text="{DynamicResource Rotate.Title}"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       Margin="0,0,0,16"/>

            <!-- Input -->
            <materialDesign:Card Padding="16" Margin="0,0,0,16"
                                 AllowDrop="True"
                                 PreviewDragOver="InputFile_DragOver"
                                 PreviewDrop="InputFile_Drop">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBox Text="{Binding InputFileName}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Common.InputFile}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 IsReadOnly="True"/>
                        <TextBlock Margin="0,4,0,0" Opacity="0.6" FontSize="12">
                            <Run Text="{DynamicResource Common.PageCountPrefix}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding InputPageCount, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Content="{DynamicResource Common.Browse}"
                            Command="{Binding BrowseInputCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}" VerticalAlignment="Bottom"/>
                </Grid>
            </materialDesign:Card>

            <!-- Angle -->
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Rotate.Angle}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="90°" IsChecked="{Binding SelectedAngle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=90}"
                                     Style="{StaticResource MaterialDesignRadioButton}" Margin="0,0,16,0"/>
                        <RadioButton Content="180°" IsChecked="{Binding SelectedAngle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=180}"
                                     Style="{StaticResource MaterialDesignRadioButton}" Margin="0,0,16,0"/>
                        <RadioButton Content="270°" IsChecked="{Binding SelectedAngle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=270}"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Page selection -->
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource Rotate.ApplyTo}" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,8"/>
                    <RadioButton Content="{DynamicResource Rotate.AllPages}"
                                 IsChecked="{Binding PageSelectionMode, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=All}"
                                 Style="{StaticResource MaterialDesignRadioButton}" Margin="0,4"/>
                    <RadioButton Content="{DynamicResource Rotate.EvenPages}"
                                 IsChecked="{Binding PageSelectionMode, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Even}"
                                 Style="{StaticResource MaterialDesignRadioButton}" Margin="0,4"/>
                    <RadioButton Content="{DynamicResource Rotate.OddPages}"
                                 IsChecked="{Binding PageSelectionMode, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Odd}"
                                 Style="{StaticResource MaterialDesignRadioButton}" Margin="0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="{DynamicResource Rotate.Selection}"
                                     IsChecked="{Binding PageSelectionMode, Converter={StaticResource StringEqualsToBoolConverter}, ConverterParameter=Custom}"
                                     Style="{StaticResource MaterialDesignRadioButton}" Margin="0,4" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding PageSelectionText}"
                                 Width="160" Margin="16,0,8,0"
                                 materialDesign:HintAssist.Hint="{DynamicResource Common.PageSelectionHint}"
                                 Style="{StaticResource MaterialDesignTextBox}"/>
                        <!-- Opens the inline thumbnail picker panel; disabled until a file is loaded -->
                        <Button Content="{DynamicResource Rotate.PickPages}"
                                Command="{Binding OpenPagePickerCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                VerticalAlignment="Center" Padding="8,0"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- Page picker panel — shown when IsPagePickerOpen -->
            <materialDesign:Card Padding="12" Margin="0,0,0,16"
                                 Visibility="{Binding IsPagePickerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>

                    <!-- Header: title + action buttons -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="{DynamicResource Rotate.Picker.Title}"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="{DynamicResource Rotate.Picker.SelectAll}"
                                    Command="{Binding PickerSelectAllCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="8,0"/>
                            <Button Content="{DynamicResource Rotate.Picker.ClearAll}"
                                    Command="{Binding PickerClearAllCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}" Padding="8,0"/>
                            <Button Content="{DynamicResource Rotate.Picker.Apply}"
                                    Command="{Binding ApplyPagePickerCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Margin="8,0,4,0" Padding="12,0"/>
                            <Button Command="{Binding ClosePagePickerCommand}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    Width="32" Height="32"
                                    ToolTip="{DynamicResource Common.Cancel}">
                                <materialDesign:PackIcon Kind="Close"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <!-- Loading spinner while thumbnails are generating -->
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True" Value="0" Width="28" Height="28"
                                 HorizontalAlignment="Center" Margin="0,8"
                                 Visibility="{Binding IsLoadingThumbs, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- Thumbnail grid — max-height prevents page from growing too tall -->
                    <ScrollViewer MaxHeight="340" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PickerPanel" ItemsSource="{Binding PageThumbs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:RotatePageThumb}">
                                    <!-- Each tile is a flat button so the whole area is clickable -->
                                    <Button Padding="0" Margin="3"
                                            Width="72" Height="100"
                                            MinWidth="0" MinHeight="0"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Command="{Binding DataContext.TogglePageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid Width="72" Height="100">
                                            <!-- Thumbnail image (or placeholder) -->
                                            <Border BorderBrush="{DynamicResource PrimaryHueMidBrush}"
                                                    BorderThickness="{Binding IsSelected, Converter={StaticResource BoolToThicknessConverter}}"
                                                    Background="#12000000" CornerRadius="2">
                                                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                                                       Visibility="{Binding Thumbnail, Converter={StaticResource IsNotNullToVisibilityConverter}}"/>
                                            </Border>

                                            <!-- Placeholder while loading -->
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Visibility="{Binding Thumbnail, Converter={StaticResource IsNullToVisibilityConverter}}">
                                                <materialDesign:PackIcon Kind="FileOutline" Width="28" Height="36"
                                                                         Foreground="#60808080" HorizontalAlignment="Center"/>
                                                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="14" Height="14"
                                                                         Foreground="#C0FF8800" HorizontalAlignment="Center"
                                                                         Margin="0,3,0,0"
                                                                         Visibility="{Binding ThumbnailFailed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- Blue selection overlay -->
                                            <Border Background="#AD1A237E" CornerRadius="2"
                                                    Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <materialDesign:PackIcon Kind="Check" Width="28" Height="28"
                                                                         Foreground="White"
                                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Page number badge -->
                                            <TextBlock Text="{Binding PageNumber}"
                                                       FontSize="10" HorizontalAlignment="Center"
                                                       VerticalAlignment="Bottom" Margin="0,0,0,2"
                                                       Background="#88000000" Foreground="White" Padding="2,1"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </materialDesign:Card>

            <!-- Output -->
            <materialDesign:Card Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <CheckBox Content="{DynamicResource Rotate.Overwrite}"
                              IsChecked="{Binding OverwriteOriginal}"
                              Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource Rotate.OverwriteWarning}"
                               Foreground="OrangeRed" FontSize="12"
                               Visibility="{Binding OverwriteOriginal, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <Grid Visibility="{Binding OverwriteOriginal, Converter={StaticResource InverseBoolToVisibilityConverter}}" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding OutputPath}"
                                 materialDesign:HintAssist.Hint="{DynamicResource Common.OutputFile}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 IsReadOnly="True" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="{DynamicResource Common.Browse}"
                                Command="{Binding BrowseOutputCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}" VerticalAlignment="Bottom"/>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <Button Content="{DynamicResource Common.Run}"
                    Command="{Binding RunCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    HorizontalAlignment="Left" Padding="32,8"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
